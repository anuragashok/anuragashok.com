{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "declaration": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "#velite": ["./.velite"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".velite/index.d.ts"],
  "exclude": ["node_modules"]
}
