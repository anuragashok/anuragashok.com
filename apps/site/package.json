{
  "name": "@anuragashok/site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "velite --clean",
    "dev": "next dev",
    "prebuild": "velite --clean",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "velite --clean && tsc --noEmit",
