# The public origin of the site. No trailing slash.
#
# REQUIRED for any production build — `apps/site/lib/site.ts` throws without it.
# Everything that names the site to the outside world derives from this value:
# feed.xml links/guids, sitemap.xml, robots.txt's sitemap pointer, canonicals,
# JSON-LD, and metadataBase for OG images.
#
# On Vercel: set it in the project environment (Production + Preview).
# Locally: copy this file to `.env.local` (gitignored) if you need to run a
# production build. `pnpm dev` works without it and falls back to localhost.
NEXT_PUBLIC_BASE_URL=https://anuragashok.com
