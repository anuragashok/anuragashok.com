{
  "name": "anuragashok.com",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "gen": "pnpm --filter @anuragashok/profile gen",
    "dev": "pnpm gen && pnpm --filter @anuragashok/site dev",
    "build": "pnpm gen && pnpm --filter @anuragashok/site build",
    "start": "pnpm --filter @anuragashok/site start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @anuragashok/site test:e2e",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.9.0"
  }
}
